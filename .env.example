# Copy to .env.local for local dev, or set these in DirectAdmin -> Node.js app config for prod.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_POOL_SIZE=5

# Long random string used to sign session cookies. Generate: openssl rand -hex 32
AUTH_SECRET=

# First admin account, created by `npm run seed:admin`
ADMIN_USER=admin
ADMIN_PASS=change-me
